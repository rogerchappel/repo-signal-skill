{
  "name": "repo-signal-skill",
  "version": "0.1.0",
  "description": "Local repository signal maps for agent launch, review, and maintenance workflows.",
  "type": "module",
  "license": "MIT",
  "author": "Roger Chappel",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/repo-signal-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/repo-signal-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/repo-signal-skill#readme",
  "bin": {
    "repo-signal-skill": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "SKILL.md",
    "docs",
    "fixtures",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^5.5.4"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "npm run check",
    "test": "npm run build && node --test test/*.test.js",
    "smoke": "npm run build && node dist/cli.js scan fixtures/node-package --format markdown",
    "package:smoke": "npm run build && node scripts/package-smoke.mjs",
    "release:check": "npm run lint && npm test && npm run smoke && npm run package:smoke"
  }
}
